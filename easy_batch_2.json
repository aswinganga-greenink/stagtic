        "output_format": "A single integer denoting the border sum.",
        "constraints": [
            "1 <= R, C <= 100",
            "-10,000 <= Matrix[i][j] <= 10,000"
        ],
        "test_cases": [
            {
                "input": "3 3\n1 2 3\n4 5 6\n7 8 9",
                "output": "40",
                "explanation": "Border elements: 1, 2, 3, 4, 6, 7, 8, 9. Sum = 40."
            },
            {
                "input": "1 4\n10 20 30 40",
                "output": "100",
                "explanation": "Complete matrix is the border."
            },
            {
                "input": "4 1\n5\n10\n15\n20",
                "output": "50",
                "explanation": "Complete matrix is the border."
            },
            {
                "input": "1 1\n100",
                "output": "100",
                "explanation": "Edge case: single element."
            },
            {
                "input": "2 2\n1 2\n3 4",
                "output": "10",
                "explanation": "No inner elements, sum is 1+2+3+4 = 10."
            }
        ]
    },
